{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the main window: own commands, dialog plugin.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open"
  ]
}
